# Copy this file to .env.langfuse and replace the placeholder secrets.
# Keep values unquoted to match Langfuse headless-initialization guidance.
NEXTAUTH_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:replace-me@postgres:5432/postgres
NEXTAUTH_SECRET=replace-me
SALT=replace-me
ENCRYPTION_KEY=replace-me-with-64-hex-characters
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=postgres
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=replace-me
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=replace-me
REDIS_AUTH=replace-me
TELEMETRY_ENABLED=false
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=false
LANGFUSE_INIT_ORG_ID=xs2n-local-org
LANGFUSE_INIT_ORG_NAME=xs2n-local
LANGFUSE_INIT_PROJECT_ID=xs2n-local-project
LANGFUSE_INIT_PROJECT_NAME=xs2n-local
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-replace-me
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-replace-me
LANGFUSE_INIT_USER_EMAIL=admin@xs2n.local
LANGFUSE_INIT_USER_NAME=xs2n-admin
LANGFUSE_INIT_USER_PASSWORD=replace-me
